[Unit]
Description=Gunicorn for transparent-input
After=network.target

[Service]
User=deploy
Group=deploy
WorkingDirectory=/home/deploy/transparent-input/django-backend
EnvironmentFile=/etc/transparent-input.env
ExecStart=/home/deploy/transparent-input/django-backend/.venv/bin/gunicorn backend.wsgi --bind 127.0.0.1:8000 --workers 2
ExecReload=/bin/kill -s HUP $MAINPID
Restart=on-failure

[Install]
WantedBy=multi-user.target
